# Backend selection: public_json (no keys, slower) or praw (needs Reddit app)
REDDIT_BACKEND=public_json

# Required only when REDDIT_BACKEND=praw
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Reddit requires a custom identifying User-Agent for any traffic
REDDIT_USER_AGENT=demand-radar-local/0.1 by u_yourusername

DATABASE_PATH=data/demand_radar.sqlite3
REPORTS_DIR=reports
LLM_PROVIDER=none
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
